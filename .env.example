# HuggingFace — get from huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Groq — get from console.groq.com (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI — get from platform.openai.com (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Pushover — get from pushover.net (optional, for deal notifications)
PUSHOVER_USER=your_pushover_user_key_here
PUSHOVER_TOKEN=your_pushover_app_token_here
